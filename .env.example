# Database
DATABASE_URL="postgresql://user:password@localhost:5432/nextjs_boilerplate?schema=public"
TEST_DATABASE_URL="postgresql://user:password@localhost:5433/nextjs_boilerplate_test?schema=public"

# App URL (used to build Entra redirect URI and validate returnTo)
APP_URL="http://localhost:3000"

# Auth session secret — 32+ bytes base64. Generate with: openssl rand -base64 32
AUTH_SESSION_SECRET="replace-me-with-openssl-rand-base64-32-output"

# Microsoft Entra ID (Azure AD)
AZURE_AD_CLIENT_ID="your-azure-ad-client-id"
AZURE_AD_CLIENT_SECRET="your-azure-ad-client-secret"
AZURE_AD_TENANT_ID="your-azure-ad-tenant-id"

# OpenTelemetry
OTEL_SERVICE_NAME="nextjs-boilerplate"
OTEL_SERVICE_VERSION="0.1.0"
OTEL_EXPORTER_OTLP_ENDPOINT="http://localhost:4318"
OTEL_EXPORTER_OTLP_PROTOCOL="http/protobuf"
OTEL_TRACES_SAMPLER="parentbased_traceidratio"
OTEL_TRACES_SAMPLER_ARG="1.0"
NODE_ENV="development"

# Application
NEXT_PUBLIC_APP_URL="http://localhost:3000"
OPENAI_API_KEY="key-here-sh"

# Yjs / y-websocket (self-hosted collaborative canvas)
NEXT_PUBLIC_YJS_HOST="localhost"
NEXT_PUBLIC_YJS_PORT="1234"

# Cron secret (protects /api/cron/* routes)
CRON_SECRET="change-me-in-production"

TAVILY_API_KEY="keyhere"